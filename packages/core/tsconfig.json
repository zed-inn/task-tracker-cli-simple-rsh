{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "nodenext",

    "paths": {
      "@errors/*": ["./src/domain/errors/*", "./src/application/errors/*"],
      "@interfaces/*": ["./src/application/interfaces/*"],
      "@app/*": ["./src/application/*"],
      "@domain/*": ["./src/domain/*"]
    },
    "esModuleInterop": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,

    "verbatimModuleSyntax": false,
    "isolatedModules": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "composite": true
  },
  "include": ["src"]
}
